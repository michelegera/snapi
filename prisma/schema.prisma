// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider = "prisma-pothos-types"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id          String   @id @default(cuid())
  name        String
  description String
  cost        Int
  power       Int
  abilities   String[]
  source      String

  @@map("card")
}

model Location {
  id          String   @id @default(cuid())
  name        String
  description String
  rarity      String
  difficulty  String
  abilities   String[]
  released    Boolean

  @@map("location")
}
